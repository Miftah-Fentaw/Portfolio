{
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "useTabs": false,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "plugins": ["@prettier/plugin-pug"],
    "overrides": [
      {
        "files": "*.pug",
        "options": {
          "tabWidth": 2,
          "singleQuote": false
        }
      }
    ]
  }


  