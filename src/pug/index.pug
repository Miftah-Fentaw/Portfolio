    // --- Custom Scripts for Modal Functionality ---
    script.
      document.addEventListener('DOMContentLoaded', function () {
        // 1. Move the modal to the body for correct stacking and event handling.
        const previewModal = document.getElementById('previewModal');
        if (previewModal) {
          document.body.appendChild(previewModal);
        }

        // 2. Add a more robust event listener to handle showing the modal.
        // This ensures Bootstrap's event listeners (for closing) are always active.
        document.querySelectorAll('[data-bs-toggle="modal"]').forEach(trigger => {
          trigger.addEventListener('click', function (event) {
            const targetSelector = this.getAttribute('data-bs-target');
            const modalElement = document.querySelector(targetSelector);
            if (modalElement) {
              const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
              modal.show();
            }
          });
        });
      });
