      // Navigation
      include includes/navbar.pug

      // Home Section
      header#home.py-5
        .container.px-5.pb-5
          .row.gx-5.align-items-center
            .col-lg-6.col-xxl-5
              // Header text content
              .text-center.text-lg-start
                .badge.bg-gradient-primary-to-secondary.text-white.mb-4.px-4.py-2
                  .text-uppercase.fw-bold 🚀 Junior Mobile Developer & IT Student
                .fs-3.fw-light.text-muted.mb-2 Building the future with passion and dedication
                h1.display-3.fw-bolder.mb-4
                  span.text-gradient.d-inline Mobile & Web Development
                .developer-tagline.mb-4
                  p.lead.text-muted.fw-light Transforming ideas into powerful, scalable applications with cutting-edge technology
                .cta-buttons.d-flex.gap-3.justify-content-center.justify-content-lg-start
                  a.btn.btn-primary.btn-lg.px-4.py-3(href="#projects")
                    i.bi.bi-code-slash.me-2
                    | View My Work
                  a.btn.btn-outline-primary.btn-lg.px-4.py-3(href="#contact")
                    i.bi.bi-envelope.me-2
                    | Let's Connect
            .col-lg-6.col-xxl-7
              // Profile Image with artistic styling
              .text-center
                .profile-image-container
                  img.img-fluid.profile-image(
                    src="assets/profile.png",
                    alt="Miftah Fentaw - Developer",
                    style="max-width: 300px; border-radius: 50%; border: 4px solid rgba(30, 48, 243, 0.2); box-shadow: 0 10px 30px rgba(30, 48, 243, 0.3)"
                  )
