              // Preview Modal
              #previewModal.modal.fade(tabindex='-1', aria-labelledby='previewModalLabel', aria-hidden='true')
                .modal-dialog.modal-lg.modal-dialog-centered
                  .modal-content
                    .modal-header
                      h5#previewModalLabel.modal-title Project Preview
                      button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
                    .modal-body
                      #previewCarousel.carousel.slide(data-bs-ride='carousel')
                        .carousel-inner
                          // Carousel items will be injected here by JavaScript
                        button.carousel-control-prev(type='button', data-bs-target='#previewCarousel', data-bs-slide='prev')
                          span.carousel-control-prev-icon(aria-hidden='true')
                          span.visually-hidden Previous
                        button.carousel-control-next(type='button', data-bs-target='#previewCarousel', data-bs-slide='next')
                          span.carousel-control-next-icon(aria-hidden='true')
                          span.visually-hidden Next

    // Contact Section
section#contact.py-5
  .container.px-5.my-5
    .text-center.mb-5
      h2.display-5.fw-bolder.mb-4
        span.text-gradient.d-inline Let's Build Something Amazing Together
      p.lead.fw-light.mb-4 Ready to turn your ideas into reality? Let's discuss your next project!
    .row.gx-5.justify-content-center
      .col-lg-8.col-xl-6.col-xxl-4
        form#contactForm(data-sb-form-api-token="API_TOKEN")
          .form-floating.mb-3
            input#name.form-control(
              type="text",
              placeholder="Enter your name...",
              data-sb-validations="required"
            )
            label(for="name") Full name
            .invalid-feedback(data-sb-feedback="name:required") A name is required.
          .form-floating.mb-3
            input#email.form-control(
              type="email",
              placeholder="name@example.com",
              data-sb-validations="required,email"
            )
            label(for="email") Email address
            .invalid-feedback(data-sb-feedback="email:required") An email is required.
            .invalid-feedback(data-sb-feedback="email:email") Email is not valid.
          .form-floating.mb-3
            select#projectType.form-control(data-sb-validations="required")
              option(value="") Select project type...
              option(value="mobile-app") Mobile App Development
              option(value="web-app") Web Application
              option(value="full-stack") Full Stack Solution
              option(value="consultation") Technical Consultation
              option(value="other") Other
            label(for="projectType") Project Type
            .invalid-feedback(data-sb-feedback="projectType:required") Please select a project type.
          .form-floating.mb-3
            textarea#message.form-control(
              placeholder="Tell me about your project...",
              style="height: 10rem",
              data-sb-validations="required"
            )
            label(for="message") Project Details
            .invalid-feedback(data-sb-feedback="message:required") Please tell me about your project.
          // Submit success message
          #submitSuccessMessage.d-none
            .text-center.mb-3
              .fw-bolder.text-success.mb-2
                i.bi.bi-check-circle.me-2
                | Message sent successfully!
              p.text-muted I'll get back to you within 24 hours to discuss your project.
          // Submit error message
          #submitErrorMessage.d-none
            .text-center.text-danger.mb-3
              i.bi.bi-exclamation-triangle.me-2
              | Error sending message!
          // Submit Button
          .d-grid
            button#submitButton.btn.btn-primary.btn-lg.px-4.py-3(type="submit")
              i.bi.bi-send.me-2
              | Send Message

        // Footer
        include includes/footer.pug

        include includes/scripts.pug
